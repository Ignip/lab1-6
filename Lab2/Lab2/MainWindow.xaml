<Window x:Class="Lab2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Игра-кликер" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#2C3E50">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Wheat" Padding="15">
            <TextBlock Text="ИГРА-КЛИКЕР" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="White"/>
        </Border>

        
        <Border Grid.Row="1" Grid.Column="0" Background="Wheat" Margin="10" 
                CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="ИНФОРМАЦИЯ ИГРОКА" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="Уровень:" FontSize="16"/>
                        <TextBlock x:Name="LvlText" Text="1" FontSize="24" 
                                   FontWeight="Bold" Foreground="#F39C12"/>
                    </StackPanel>
                </Border>

                <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="Золото:" FontSize="16"/>
                        <TextBlock x:Name="GoldText" Text="0" FontSize="24" 
                                   FontWeight="Bold" Foreground="#F1C40F"/>
                    </StackPanel>
                </Border>

                <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="Урон:" FontSize="16"/>
                        <TextBlock x:Name="DamageText" Text="10" FontSize="24" 
                                   FontWeight="Bold" Foreground="Pink"/>
                    </StackPanel>
                </Border>

                <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="Стоимость улучшения:" FontSize="16"/>
                        <TextBlock x:Name="UpgradeCostText" Text="100" FontSize="20" 
                                   FontWeight="Bold" Foreground="#E67E22"/>
                    </StackPanel>
                </Border>

                <Button x:Name="UpgradeButton" Content="УЛУЧШИТЬ УРОН" 
                        Click="UpgradeButton_Click" Margin="0,20,0,0" 
                        Background="#E67E22" FontSize="16"/>

                <Button x:Name="LoadEnemiesButton" Content="ЗАГРУЗИТЬ ПРОТИВНИКОВ" 
                        Click="LoadEnemiesButton_Click" Margin="0,10,0,0" 
                        Background="#3498DB" FontSize="14"/>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="1" Grid.Column="1" Background="Wheat" Margin="10" 
                CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="ТЕКУЩИЙ ПРОТИВНИК" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="#2C3E50" CornerRadius="10" Padding="20" 
                        HorizontalAlignment="Center" Width="300" Height="300">
                    <StackPanel>
                        <Image x:Name="EnemyImage" Width="150" Height="150" 
                               HorizontalAlignment="Center" Margin="0,20"/>
                        <TextBlock x:Name="EnemyNameText" Text="Нет противника" 
                                   FontSize="18" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Margin="0,10"/>
                        <TextBlock Text="Здоровье:" FontSize="14" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock x:Name="EnemyHealthText" Text="0" FontSize="20" 
                                   FontWeight="Bold" Foreground="#E74C3C" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Награда:" FontSize="14" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock x:Name="EnemyRewardText" Text="0" FontSize="16" 
                                   Foreground="#F1C40F" HorizontalAlignment="Center" Cursor=""/>
                    </StackPanel>
                </Border>

                <Button x:Name="AttackButton" Content="АТАКОВАТЬ" 
                        Click="AttackButton_Click" Margin="0,30,0,0" 
                        Background="Orange" FontSize="18" Height="50"/>
            </StackPanel>
        </Border>

        <!-- Нижняя панель - Статистика -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="EnemiesDefeatedText" Text="Побеждено: 0" 
                           FontSize="14" Margin="20,0"/>
                <TextBlock x:Name="TotalDamageText" Text="Всего урона: 0" 
                           FontSize="14" Margin="20,0"/>
                <TextBlock x:Name="HighestDamageText" Text="Макс. урон: 0" 
                           FontSize="14" Margin="20,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>