<Window x:Class="Lab4._2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Игра-кликер" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#2C3E50">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Wheat" Padding="8" CornerRadius="5" Margin="0,0,0,5">
            <TextBlock Text="ИГРА-КЛИКЕР" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0">
            <Border Background="Wheat" CornerRadius="8" Padding="10">
                <StackPanel>
                    <TextBlock Text="ИНФОРМАЦИЯ ИГРОКА" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <Border Background="#2C3E50" CornerRadius="5" Padding="8" Margin="0,3">
                        <StackPanel>
                            <TextBlock Text="Уровень:" FontSize="12"/>
                            <TextBlock x:Name="LvlText" Text="1" FontSize="20" 
                                       FontWeight="Bold" Foreground="#F39C12"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C3E50" CornerRadius="5" Padding="8" Margin="0,3">
                        <StackPanel>
                            <TextBlock Text="Золото:" FontSize="12"/>
                            <TextBlock x:Name="GoldText" Text="0" FontSize="20" 
                                       FontWeight="Bold" Foreground="#F1C40F"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C3E50" CornerRadius="5" Padding="8" Margin="0,3">
                        <StackPanel>
                            <TextBlock Text="Урон:" FontSize="12"/>
                            <TextBlock x:Name="DamageText" Text="10" FontSize="20" 
                                       FontWeight="Bold" Foreground="Pink"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C3E50" CornerRadius="5" Padding="8" Margin="0,3">
                        <StackPanel>
                            <TextBlock Text="Стоимость улучшения урона:" FontSize="11"/>
                            <TextBlock x:Name="UpgradeCostText" Text="100" FontSize="16" 
                                       FontWeight="Bold" Foreground="#E67E22"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="UpgradeButton" Content="УЛУЧШИТЬ УРОН" 
                            Click="UpgradeButton_Click" Margin="0,5" 
                            Background="#E67E22" FontSize="12"/>

                    <Border Background="#2C3E50" CornerRadius="5" Padding="8" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="ПЕРЕЗАРЯДКА АТАКИ" FontSize="12" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <TextBlock x:Name="CooldownText" Text="Готов к атаке!" FontSize="11" 
                                       Foreground="#F1C40F" HorizontalAlignment="Center"/>
                            <TextBlock Text="Стоимость:" FontSize="10" Margin="0,3,0,0"/>
                            <TextBlock x:Name="UpgradeCooldownCostText" Text="100" FontSize="14" 
                                       FontWeight="Bold" Foreground="Blue" HorizontalAlignment="Center"/>
                            <Button x:Name="UpgradeCooldownButton" Content="УЛУЧШИТЬ ПЕРЕЗАРЯДКУ" 
                                    Click="UpgradeCooldownButton_Click" Margin="0,3" 
                                    Background="Blue" FontSize="10"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="DamageBoostText" Text="" FontSize="10" 
                               Foreground="#E74C3C" HorizontalAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,3"/>

                    <TextBlock x:Name="WeakenText" Text="" FontSize="10" 
                               Foreground="#E67E22" HorizontalAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,3"/>

                    <Button x:Name="LoadEnemiesButton" Content="ЗАГРУЗИТЬ ПРОТИВНИКОВ" 
                            Click="LoadEnemiesButton_Click" Margin="0,5" 
                            Background="#3498DB" FontSize="11"/>

                    <Button x:Name="SaveGameButton" Content="СОХРАНИТЬ ИГРУ" 
                            Click="SaveGameButton_Click" Margin="0,3" 
                            Background="#27AE60" FontSize="11"/>

                    <Button x:Name="LoadGameButton" Content="ЗАГРУЗИТЬ ИГРУ" 
                            Click="LoadGameButton_Click" Margin="0,3" 
                            Background="#F39C12" FontSize="11"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Background="Wheat" CornerRadius="8" Padding="10" Margin="5,0,0,0">
            <StackPanel>
                <TextBlock Text="ТЕКУЩИЙ ПРОТИВНИК" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Border Background="#2C3E50" CornerRadius="10" Padding="15" 
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <Image x:Name="EnemyImage" Width="120" Height="120" 
                               HorizontalAlignment="Center" Margin="0,10"/>
                        <TextBlock x:Name="EnemyNameText" Text="Нет противника" 
                                   FontSize="16" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Margin="0,5"/>
                        <TextBlock x:Name="EnemyTypeText" Text="" FontSize="10" 
                                   Foreground="#F39C12" HorizontalAlignment="Center" 
                                   Margin="0,3"/>
                        <TextBlock Text="Здоровье:" FontSize="12" 
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EnemyHealthText" Text="0" FontSize="18" 
                                   FontWeight="Bold" Foreground="#E74C3C" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Награда:" FontSize="12" 
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock x:Name="EnemyRewardText" Text="0" FontSize="14" 
                                   Foreground="#F1C40F" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="AttackButton" Content="АТАКОВАТЬ" 
                        Click="AttackButton_Click" Margin="0,20" 
                        Background="#E74C3C" FontSize="16" Height="45"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2C3E50" Padding="8" CornerRadius="5" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="EnemiesDefeatedText" Text="Побеждено: 0" 
                           FontSize="11" Margin="15,0"/>
                <TextBlock x:Name="TotalDamageText" Text="Всего урона: 0" 
                           FontSize="11" Margin="15,0"/>
                <TextBlock x:Name="HighestDamageText" Text="Макс. урон: 0" 
                           FontSize="11" Margin="15,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>