<Window x:Class="lab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор противников" Height="620.292" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

      
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Редактор противников" 
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>

      
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Margin="5">
            <StackPanel>
                <TextBlock Text="Иконки противников" FontSize="16" FontWeight="Bold" 
                           Margin="10" TextAlignment="Center"/>
                <Button Content="Выбрать папку с иконками" Click="SelectFolder_Click" 
                        Margin="10" Padding="5"/>
                <ListBox x:Name="IconsListBox" Height="300" Margin="10" 
                         SelectionChanged="IconsListBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Центральная панель - форма создания/редактирования -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Margin="5" Width="300">
            <StackPanel Margin="10">
                <TextBlock Text="Информация о противнике" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,10" TextAlignment="Center"/>

                <TextBlock Text="Название:" Margin="0,5,0,0"/>
                <TextBox x:Name="NameTextBox" Margin="0,0,0,5"/>

                <TextBlock Text="Выбранная иконка:" Margin="0,5,0,0"/>
                <TextBox x:Name="SelectedIconTextBox" IsReadOnly="True" 
                         Background="LightGray" Margin="0,0,0,5"/>

                <TextBlock Text="Базовое здоровье:" Margin="0,5,0,0"/>
                <TextBox x:Name="BaseLifeTextBox" Margin="0,0,0,5"/>

                <TextBlock Text="Модификатор здоровья:" Margin="0,5,0,0"/>
                <TextBox x:Name="LifeModifierTextBox" Margin="0,0,0,5"/>

                <TextBlock Text="Базовое золото:" Margin="0,5,0,0"/>
                <TextBox x:Name="BaseGoldTextBox" Margin="0,0,0,5"/>

                <TextBlock Text="Модификатор золота:" Margin="0,5,0,0"/>
                <TextBox x:Name="GoldModifierTextBox" Margin="0,0,0,5"/>

                <TextBlock Text="Шанс появления (0-1):" Margin="0,5,0,0"/>
                <TextBox x:Name="SpawnChanceTextBox" Margin="0,0,0,10"/>
                <Button Content="Добавить противника" Click="AddEnemy_Click" 
                        Margin="0,5,0.4,5" Padding="5" Background="Orange"/>
                <Button Content="Удалить выбранного" Click="DeleteEnemy_Click" 
                        Margin="0,5,0.4,5" Padding="5" Background="Red"/>
            </StackPanel>
        </Border>

        <!-- Правая панель - список противников -->
        <Border Grid.Row="1" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Margin="5">
            <StackPanel>
                <TextBlock Text="Список противников" FontSize="16" FontWeight="Bold" 
                           Margin="10" TextAlignment="Center"/>
                <ListBox x:Name="EnemiesListBox" Height="300" Margin="10" 
                         SelectionChanged="EnemiesListBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button Content="Сохранить в JSON" Click="SaveToJson_Click" 
                    Padding="10" Margin="5" Width="120"/>
            <Button Content="Загрузить из JSON" Click="LoadFromJson_Click" 
                    Padding="10" Margin="5" Width="120"/>
            <Button Content="Очистить все" Click="ClearAll_Click" 
                    Padding="10" Margin="5" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
