<Window x:Class="WordTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тренажер иностранных слов" Height="617.608" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="📚 Тренажер для запоминания иностранных слов" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="LightGray" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Выберите категорию:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                <ComboBox x:Name="cmbCategories" Width="200" SelectionChanged="CmbCategories_SelectionChanged"/>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Margin="10,0,0,0" 
                        Click="BtnRefresh_Click" Background="#FFE0E0E0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="LightGray" BorderThickness="1" 
                CornerRadius="5" Padding="20" Margin="0,0,0,10" Background="White">
            <StackPanel>
                <TextBlock Text="Текущее слово:" FontSize="12" Foreground="Gray"/>
                <TextBlock x:Name="txtCurrentWord" FontSize="28" FontWeight="Bold" Margin="0,5,0,15" 
                           HorizontalAlignment="Center" Text="Выберите категорию"/>

                <TextBlock Text="Выберите правильный перевод:" FontSize="12" Foreground="Gray" Margin="0,0,0,10"/>
                <ItemsControl x:Name="itemsOptions">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton x:Name="rbOption" GroupName="AnswerGroup" Content="{Binding}" 
                                         Margin="0,5" FontSize="14" Checked="RadioButton_Checked"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="btnCheck" Content="✓ Проверить ответ" Width="150" Height="35" 
                            Click="BtnCheck_Click" IsEnabled="False" Background="#FF4CAF50" Foreground="White"/>
                    <Button x:Name="btnNext" Content="→ Следующее слово" Width="150" Height="35" 
                            Margin="10,0,0,0" Click="BtnNext_Click" IsEnabled="False" Background="#FF2196F3" Foreground="White"/>
                </StackPanel>

                <TextBlock x:Name="txtResult" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="LightGray" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#FFF9E6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Правильных ответов:" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="1" x:Name="txtCorrectCount" Text="0" FontSize="20" FontWeight="Bold" 
                           Foreground="Green" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Неправильных ответов:" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="3" x:Name="txtWrongCount" Text="0" FontSize="20" FontWeight="Bold" 
                           Foreground="Red" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Всего ответов:" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="5" x:Name="txtTotalCount" Text="0" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnAddWord" Content="➕ Добавить новое слово" Width="180" Height="35" 
                    Click="BtnAddWord_Click" Background="#FF9C27B0" Foreground="White"/>
            <Button x:Name="btnSaveData" Content="💾 Сохранить данные" Width="150" Height="35" 
                    Margin="10,0,0,0" Click="BtnSaveData_Click" Background="#FF607D8B" Foreground="White"/>
            <Button x:Name="btnLoadData" Content="📂 Загрузить данные" Width="150" Height="35" 
                    Margin="10,0,0,0" Click="BtnLoadData_Click" Background="#FF607D8B" Foreground="White"/>
        </StackPanel>

        <StatusBar Grid.Row="5" Grid.ColumnSpan="2" VerticalAlignment="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готов к работе" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>